# .env.example — Production environment template
# Copy to .env.prod and fill in all values before deploying.

# ── Server ────────────────────────────────────────────────────────────────────
# Full URL of the server as seen by browsers (no trailing slash)
FRONTEND_URL=https://192.168.x.x

# Path on the VM where allocator CSV files are stored
ALLOCATOR_CSV_PATH=/opt/allocator-csv

# ── Image registry ────────────────────────────────────────────────────────────
# Registry prefix with trailing slash, e.g. "ghcr.io/yourorg/" or "192.168.x.x:5000/"
REGISTRY=
TAG=latest

# ── Secrets ──────────────────────────────────────────────────────────────────
# Generate OPENCLAW_TOKEN with: openssl rand -hex 24
OPENCLAW_TOKEN=
POSTGRES_PASSWORD=postgres
PGADMIN_PASSWORD=securepassword

# ── AI ────────────────────────────────────────────────────────────────────────
# Allocator LLM provider:
#   openclaw  (default) — route impact-assessment + planning-copilot through the
#                         OpenClaw gateway, reusing its provider/credentials.
#                         No extra API key needed beyond OPENCLAW_TOKEN.
#                         Works with Claude Pro OAuth tokens (sk-ant-oat01-*).
#   anthropic           — call api.anthropic.com directly (requires a real
#                         sk-ant-api03-* API key in ANTHROPIC_API_KEY below).
#   openai              — call api.openai.com directly (requires OPENAI_API_KEY).
# (OpenClaw gateway itself always uses ANTHROPIC_API_KEY regardless of this setting.)
LLM_PROVIDER=openclaw
# Required by OpenClaw (always). Also used by the allocator when LLM_PROVIDER=anthropic.
# Accepts either a real API key (sk-ant-api03-*) or a Claude Pro OAuth token (sk-ant-oat01-*).
ANTHROPIC_API_KEY=
# Optional. Only needed when LLM_PROVIDER=openai.
OPENAI_API_KEY=

# ── Email (outbound SMTP) ─────────────────────────────────────────────────────
SMTP_HOST=smtp.yourprovider.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# ── Email (inbound IMAP — for HITL email replies) ─────────────────────────────
IMAP_HOST=imap.yourprovider.com
IMAP_PORT=993
IMAP_USER=
IMAP_PASS=

# ── Optional integrations ─────────────────────────────────────────────────────
MCP_API_KEY=
SLACK_BOT_TOKEN=
SLACK_APP_TOKEN=
TELEGRAM_BOT_TOKEN=
ADAPTOR_POLL_INTERVAL=30
