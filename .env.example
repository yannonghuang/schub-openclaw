# Copy to .env and fill in real values

# LLM
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Database
POSTGRES_URI=postgresql://postgres:postgres@db:5432/schub

# Redis
REDIS_URI=redis://redis:6379

# MCP server
MCP_API_KEY=
MCP_SERVER_URL=http://mcp-server:9500

# Backend (auth-service)
BACKEND_URL=http://auth-service:4000

# Email (IMAP/SMTP for OpenClaw email channel)
IMAP_HOST=
IMAP_PORT=993
IMAP_USER=
IMAP_PASS=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
