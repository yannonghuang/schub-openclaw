# Copy to .env and fill in real values

# ── Image registry (image-based deployment only) ─────────────────────────────
# Registry prefix — trailing slash required, e.g. "ghcr.io/yourorg/"
# Leave empty to use locally-built images (docker compose build workflow)
REGISTRY=
TAG=latest

# ── Server ───────────────────────────────────────────────────────────────────
# Full URL of this server as seen by browsers (no trailing slash)
FRONTEND_URL=https://192.168.x.x

# Path on the VM where CSV data files are stored (image-based deploy)
ALLOCATOR_CSV_PATH=/opt/allocator-csv

# ── LLM ──────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=
OPENAI_API_KEY=                    # optional — only needed for LLM assessment features

# ── Secrets ──────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 24
OPENCLAW_TOKEN=

# Postgres password (default "postgres" is fine for an isolated private network)
POSTGRES_PASSWORD=postgres

# PgAdmin UI password
PGADMIN_PASSWORD=securepassword

# ── Database (internal URLs — do not change unless you rename services) ───────
POSTGRES_URI=postgresql://postgres:${POSTGRES_PASSWORD}@db:5432/schub
REDIS_URI=redis://redis:6379

# ── MCP server ────────────────────────────────────────────────────────────────
MCP_API_KEY=
MCP_SERVER_URL=http://mcp-server:9500

# ── Backend (auth-service) ────────────────────────────────────────────────────
BACKEND_URL=http://auth-service:4000

# ── Email (IMAP inbound — openclaw + adaptor for HITL email replies) ──────────
IMAP_HOST=imap.gmail.com
IMAP_PORT=993
IMAP_USER=
IMAP_PASS=

# ── Email (SMTP outbound — auth-service and openclaw) ─────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# ── OpenClaw channel integrations (optional) ──────────────────────────────────
TELEGRAM_BOT_TOKEN=
SLACK_BOT_TOKEN=
SLACK_APP_TOKEN=

# ── Adaptor ───────────────────────────────────────────────────────────────────
ADAPTOR_POLL_INTERVAL=30           # seconds between IMAP polls
