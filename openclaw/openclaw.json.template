  "agents": {
    "defaults": {
      "heartbeat": {
        "every": "12h",
        "model": "nanogpt/openai/gpt-4o-mini" 
      },

      "model": {
        "primary": "nanogpt/minimax/minimax-m2.7",
        "fallbacks": [
          "nanogpt/minimax/minimax-m2.7",
          "nanogpt/deepseek-ai/deepseek-v3.1-terminus",
          "nanogpt/anthropic/claude-haiku-4.5",
          "nanogpt/anthropic/claude-sonnet-4.6",
          "nanogpt/openai/gpt-4o"
        ]
      },

      "models": {
        "nanogpt/openai/gpt-4o-mini": {}
      },
      "workspace": "/home/node/.openclaw/workspace",
      "subagents": {
        "maxSpawnDepth": 2
      },
      "bootstrapMaxChars": 50000,
      "bootstrapTotalMaxChars": 300000,
      "contextInjection": "always"
    },
    "list": [
      {
        "id": "main",
        "workspace": "/home/node/.openclaw/agents/main",
        "subagents": {
          "allowAgents": [
            "order",
            "material",
            "planning",
            "scheduling",
            "wip"
          ]
        },
        "model": {
          "primary": "nanogpt/anthropic/claude-haiku-4.5",
          "fallbacks": [
            "nanogpt/anthropic/claude-sonnet-4.6",
            "nanogpt/openai/gpt-4o",
            "nanogpt/minimax/minimax-m2.7"
          ]
        }
      },
      {
        "id": "order",
        "workspace": "/home/node/.openclaw/agents/order",
        "model": {
          "primary": "nanogpt/anthropic/claude-haiku-4.5",
          "fallbacks": [
            "nanogpt/anthropic/claude-sonnet-4.6",
            "nanogpt/openai/gpt-4o",
            "nanogpt/minimax/minimax-m2.7"
          ]
        }
      },
      {
        "id": "material",
        "workspace": "/home/node/.openclaw/agents/material",
        "subagents": {
          "allowAgents": [
            "order",
            "planning"
          ]
        },
        "model": {
          "primary": "nanogpt/anthropic/claude-haiku-4.5",
          "fallbacks": [
            "nanogpt/anthropic/claude-sonnet-4.6",
            "nanogpt/openai/gpt-4o",
            "nanogpt/minimax/minimax-m2.7"
          ]
        }
      },
      {
        "id": "planning",
        "workspace": "/home/node/.openclaw/agents/planning",
        "model": {
          "primary": "nanogpt/anthropic/claude-haiku-4.5",
          "fallbacks": [
            "nanogpt/anthropic/claude-sonnet-4.6",
            "nanogpt/openai/gpt-4o",
            "nanogpt/minimax/minimax-m2.7"
          ]
        }
      },
      {
        "id": "scheduling",
        "workspace": "/home/node/.openclaw/agents/scheduling"
      },
      {
        "id": "wip",
        "workspace": "/home/node/.openclaw/agents/wip"
