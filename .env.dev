# .env.dev — Development environment
# Non-sensitive defaults are pre-filled. Set ANTHROPIC_API_KEY and email credentials.

# ── Server ────────────────────────────────────────────────────────────────────
FRONTEND_URL=https://localhost

# ── Image tag (used by scripts/build-push.sh in dev) ─────────────────────────
REGISTRY=
TAG=dev

# ── Secrets ──────────────────────────────────────────────────────────────────
POSTGRES_PASSWORD=postgres
PGADMIN_PASSWORD=securepassword
OPENCLAW_TOKEN=dev-token-change-me

# ── AI ────────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# ── Email (outbound SMTP) ─────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# ── Email (inbound IMAP — for HITL email replies) ─────────────────────────────
IMAP_HOST=imap.gmail.com
IMAP_PORT=993
IMAP_USER=
IMAP_PASS=

# ── Optional integrations ─────────────────────────────────────────────────────
MCP_API_KEY=
SLACK_BOT_TOKEN=
SLACK_APP_TOKEN=
TELEGRAM_BOT_TOKEN=
ADAPTOR_POLL_INTERVAL=30
