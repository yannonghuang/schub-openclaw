'''

@app.post("/auth/signout")
def signout(
    response: Response,
    token: Optional[str] = Cookie(None),
    session: Session = Depends(get_session)
):
    if token:
        try:
            payload = decode_access_token(token)
            session_id = payload.get("session_id")
            if session_id:
                user_session = session.get(User_Session, session_id)
                if user_session and not user_session.end_time:
                    if payload.get("partner_name"):
                        if not user_session.early_out:
                            user_session.early_out = payload.get("partner_name")
                        else:
                            user_session.late_out = payload.get("partner_name")

                    if (
                        (not user_session.early_in and not user_session.late_in) and (not user_session.early_out and not user_session.late_out) or
                        ((user_session.early_in and not user_session.late_in) and (user_session.early_out and not user_session.late_out)) or
                        ((user_session.early_in and user_session.late_in) and (user_session.early_out and user_session.late_out))
                        ):
                        user_session.end_time = datetime.utcnow()

                    session.add(user_session)
                    session.commit()
        except Exception as e:
            logger.error(e)
            # Optionally log the error
    else:
        logger.info("token cookie does not exist when signout")

    response.delete_cookie("token")
    return {"message": "Signed out"}

